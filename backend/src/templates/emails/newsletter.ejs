<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            margin: 0;
            padding: 0;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
        }
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 40px 20px;
            text-align: center;
            color: white;
        }
        .header-logo {
            font-size: 28px;
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.5px;
        }
        .header-subtitle {
            font-size: 12px;
            opacity: 0.9;
            margin: 5px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .content-wrapper {
            padding: 30px 20px;
            border-bottom: 1px solid #e8e8e8;
        }
        .newsletter-title {
            font-size: 24px;
            font-weight: 700;
            color: #1f2937;
            margin: 0 0 10px 0;
            line-height: 1.3;
        }
        .newsletter-date {
            font-size: 12px;
            color: #888;
            margin: 0 0 25px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .newsletter-content {
            color: #333;
            font-size: 14px;
            line-height: 1.7;
        }
        .newsletter-content h2 {
            color: #667eea;
            font-size: 18px;
            margin: 20px 0 10px 0;
        }
        .newsletter-content h3 {
            color: #764ba2;
            font-size: 16px;
            margin: 15px 0 10px 0;
        }
        .newsletter-content p {
            margin: 10px 0;
        }
        .newsletter-content ul, .newsletter-content ol {
            margin: 10px 0;
            padding-left: 20px;
        }
        .newsletter-content li {
            margin: 5px 0;
        }
        .newsletter-content a {
            color: #667eea;
            text-decoration: none;
        }
        .newsletter-content a:hover {
            text-decoration: underline;
        }
        .newsletter-content img {
            max-width: 100%;
            height: auto;
            display: block;
            margin: 15px 0;
            border-radius: 8px;
        }
        .section {
            padding: 30px 20px;
            border-bottom: 1px solid #e8e8e8;
        }
        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
            margin: 0 0 20px 0;
            padding-bottom: 10px;
            border-bottom: 3px solid #667eea;
        }
        .news-grid {
            display: block;
        }
        .news-item {
            margin-bottom: 20px;
            border: 1px solid #e8e8e8;
            border-radius: 8px;
            overflow: hidden;
            background-color: #f9f9f9;
        }
        .news-item-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            display: block;
        }
        .news-item-content {
            padding: 15px;
        }
        .news-item-title {
            font-size: 16px;
            font-weight: 600;
            color: #1f2937;
            margin: 0 0 8px 0;
            line-height: 1.4;
        }
        .news-item-desc {
            font-size: 13px;
            color: #666;
            margin: 0;
            line-height: 1.5;
        }
        .properties-grid {
            display: block;
        }
        .property-card {
            border: 1px solid #e8e8e8;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 20px;
            background-color: #f9f9f9;
        }
        .property-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
            display: block;
        }
        .property-content {
            padding: 12px;
        }
        .property-address {
            font-size: 13px;
            font-weight: 600;
            color: #1f2937;
            margin: 0 0 5px 0;
        }
        .property-details {
            font-size: 12px;
            color: #666;
            margin: 0;
        }
        .property-detail-item {
            display: inline-block;
            margin-right: 12px;
            margin-bottom: 5px;
        }
        .agent-section {
            padding: 30px 20px;
            background: linear-gradient(135deg, #f5f7fa 0%, #eff3f8 100%);
            border-radius: 8px;
            text-align: center;
        }
        .agent-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            margin: 0 auto 15px;
            border: 3px solid #667eea;
            display: block;
        }
        .agent-name {
            font-size: 18px;
            font-weight: 700;
            color: #1f2937;
            margin: 0 0 5px 0;
        }
        .agent-title {
            font-size: 13px;
            color: #666;
            margin: 0 0 12px 0;
        }
        .agent-bio {
            font-size: 13px;
            color: #666;
            margin: 0 0 15px 0;
            line-height: 1.5;
            font-style: italic;
        }
        .agent-contact {
            font-size: 12px;
            margin: 0;
        }
        .agent-contact p {
            margin: 5px 0;
        }
        .agent-contact a {
            color: #667eea;
            text-decoration: none;
        }
        .footer {
            padding: 20px;
            background-color: #2d3748;
            color: #e8e8e8;
            font-size: 12px;
            text-align: center;
        }
        .footer a {
            color: #667eea;
            text-decoration: none;
        }
        .footer-text {
            margin: 8px 0;
        }
        .divider {
            height: 1px;
            background-color: #e8e8e8;
            margin: 20px 0;
        }
        @media (max-width: 640px) {
            .email-container {
                width: 100% !important;
            }
            .content-wrapper,
            .section,
            .agent-section {
                padding: 20px 15px !important;
            }
            .newsletter-title {
                font-size: 20px !important;
            }
            .section-title {
                font-size: 18px !important;
            }
            .agent-avatar {
                width: 100px !important;
                height: 100px !important;
            }
        }
    </style>
</head>
<body>
    <table width="100%" cellpadding="0" cellspacing="0" bgcolor="#f5f5f5">
        <tr>
            <td align="center" style="padding: 20px 0;">
                <table width="600" cellpadding="0" cellspacing="0" class="email-container" style="border-collapse: collapse; background-color: #ffffff;">
                    <!-- Header -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px; text-align: center; color: white;">
                            <h1 style="font-size: 28px; font-weight: 700; margin: 0; letter-spacing: -0.5px;">RIALTOR</h1>
                            <p style="font-size: 12px; opacity: 0.9; margin: 5px 0 0 0; text-transform: uppercase; letter-spacing: 1px;">Tu Boletín de Inmuebles</p>
                        </td>
                    </tr>

                    <!-- Main Content -->
                    <tr>
                        <td style="padding: 30px 20px; border-bottom: 1px solid #e8e8e8;">
                            <h2 style="font-size: 24px; font-weight: 700; color: #1f2937; margin: 0 0 10px 0; line-height: 1.3;"><%= title %></h2>
                            <p style="font-size: 12px; color: #888; margin: 0 0 25px 0; text-transform: uppercase; letter-spacing: 0.5px;"><%= publishDate %></p>
                            
                            <!-- Newsletter HTML Content -->
                            <div style="color: #333; font-size: 14px; line-height: 1.7;">
                                <%- contentHtml %>
                            </div>
                        </td>
                    </tr>

                    <!-- News Section (if available) -->
                    <% if (news && news.length > 0) { %>
                    <tr>
                        <td style="padding: 30px 20px; border-bottom: 1px solid #e8e8e8;">
                            <h3 style="font-size: 20px; font-weight: 700; color: #1f2937; margin: 0 0 20px 0; padding-bottom: 10px; border-bottom: 3px solid #667eea;">📰 Noticias del Mercado</h3>
                            
                            <% news.forEach(function(newsItem) { %>
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px; border: 1px solid #e8e8e8; border-radius: 8px; overflow: hidden; background-color: #f9f9f9;">
                                <% if (newsItem.image) { %>
                                <tr>
                                    <td>
                                        <img src="<%= newsItem.image %>" alt="<%= newsItem.title %>" style="width: 100%; height: 200px; object-fit: cover; display: block;">
                                    </td>
                                </tr>
                                <% } %>
                                <tr>
                                    <td style="padding: 15px;">
                                        <h4 style="font-size: 16px; font-weight: 600; color: #1f2937; margin: 0 0 8px 0; line-height: 1.4;"><%= newsItem.title %></h4>
                                        <p style="font-size: 13px; color: #666; margin: 0; line-height: 1.5;"><%= newsItem.description || '' %></p>
                                    </td>
                                </tr>
                            </table>
                            <% }) %>
                        </td>
                    </tr>
                    <% } %>

                    <!-- Properties Section (if available) -->
                    <% if (properties && properties.length > 0) { %>
                    <tr>
                        <td style="padding: 30px 20px; border-bottom: 1px solid #e8e8e8;">
                            <h3 style="font-size: 20px; font-weight: 700; color: #1f2937; margin: 0 0 20px 0; padding-bottom: 10px; border-bottom: 3px solid #667eea;">🏠 Propiedades Destacadas</h3>
                            
                            <% properties.forEach(function(property) { %>
                            <table width="100%" cellpadding="0" cellspacing="0" style="border: 1px solid #e8e8e8; border-radius: 8px; overflow: hidden; margin-bottom: 20px; background-color: #f9f9f9;">
                                <% if (property.image) { %>
                                <tr>
                                    <td>
                                        <img src="<%= property.image %>" alt="<%= property.address %>" style="width: 100%; height: 180px; object-fit: cover; display: block;">
                                    </td>
                                </tr>
                                <% } %>
                                <tr>
                                    <td style="padding: 12px;">
                                        <p style="font-size: 13px; font-weight: 600; color: #1f2937; margin: 0 0 5px 0;"><%= property.address %></p>
                                        <p style="font-size: 12px; color: #666; margin: 0;">
                                            <% if (property.bedrooms) { %>
                                                <span style="display: inline-block; margin-right: 12px; margin-bottom: 5px;">🛏️ <%= property.bedrooms %> hab</span>
                                            <% } %>
                                            <% if (property.bathrooms) { %>
                                                <span style="display: inline-block; margin-right: 12px; margin-bottom: 5px;">🚿 <%= property.bathrooms %> baños</span>
                                            <% } %>
                                            <% if (property.sqft) { %>
                                                <span style="display: inline-block; margin-right: 12px; margin-bottom: 5px;">📐 <%= property.sqft %> m²</span>
                                            <% } %>
                                            <% if (property.price) { %>
                                                <span style="display: inline-block; margin-right: 12px; margin-bottom: 5px;">💰 <%= property.price %></span>
                                            <% } %>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                            <% }) %>
                        </td>
                    </tr>
                    <% } %>

                    <!-- Agent Profile Section (if available) -->
                    <% if (agentInfo && agentInfo.name) { %>
                    <tr>
                        <td style="padding: 30px 20px; background: linear-gradient(135deg, #f5f7fa 0%, #eff3f8 100%); border-radius: 8px; text-align: center;">
                            <% if (agentInfo.photo) { %>
                            <img src="<%= agentInfo.photo %>" alt="<%= agentInfo.name %>" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin: 0 auto 15px; border: 3px solid #667eea; display: block;">
                            <% } %>
                            
                            <h3 style="font-size: 18px; font-weight: 700; color: #1f2937; margin: 0 0 5px 0;"><%= agentInfo.name %></h3>
                            <% if (agentInfo.title || agentInfo.agency) { %>
                            <p style="font-size: 13px; color: #666; margin: 0 0 12px 0;"><%= agentInfo.title %><%if(agentInfo.agency){%> | <%= agentInfo.agency %><% } %></p>
                            <% } %>
                            
                            <% if (agentInfo.bio) { %>
                            <p style="font-size: 13px; color: #666; margin: 0 0 15px 0; line-height: 1.5; font-style: italic;"><%= agentInfo.bio %></p>
                            <% } %>
                            
                            <div style="font-size: 12px; margin: 0;">
                                <% if (agentInfo.email) { %>
                                <p style="margin: 5px 0;"><strong>Email:</strong> <a href="mailto:<%= agentInfo.email %>" style="color: #667eea; text-decoration: none;"><%= agentInfo.email %></a></p>
                                <% } %>
                                <% if (agentInfo.phone) { %>
                                <p style="margin: 5px 0;"><strong>Teléfono:</strong> <a href="tel:<%= agentInfo.phone %>" style="color: #667eea; text-decoration: none;"><%= agentInfo.phone %></a></p>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% } %>

                    <!-- Footer -->
                    <tr>
                        <td style="padding: 20px; background-color: #2d3748; color: #e8e8e8; font-size: 12px; text-align: center;">
                            <p style="margin: 8px 0;"><strong>RIALTOR</strong> — Tu plataforma inmobiliaria inteligente</p>
                            <p style="margin: 8px 0;"><a href="<%= unsubscribeLink %>" style="color: #667eea; text-decoration: none;">Dar de baja de este newsletter</a></p>
                            <p style="margin: 8px 0; font-size: 11px; color: #999;">© 2026 RIALTOR. Todos los derechos reservados.</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
