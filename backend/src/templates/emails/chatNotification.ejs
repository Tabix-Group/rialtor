<%
  const body = `
    <h2>Nuevo mensaje en tu chat</h2>
    <p>Hola <%= userName %>,</p>

    <p>Tienes un nuevo mensaje en tu sesión de chat en Rialtor.</p>

    <p><strong>Avance del mensaje:</strong></p>
    <blockquote style="background-color: #f0f0f0; padding: 15px; border-left: 4px solid #1e40af; margin: 15px 0;">
      <%= messagePreview %>
    </blockquote>

    <a href="<%= chatUrl %>" class="button">Ver Chat Completo</a>

    <p style="font-size: 12px; color: #666;">
      Puedes responder directamente en tu sesión de chat.
    </p>
  `;
%>

<%- include('layout', { body, title: 'Nuevo Mensaje en Chat' }) %>
